import java.util.*;
public class Main{
    public static void main(String args[]){
        Scanner in=new Scanner(System.in);
        String s=in.nextLine();
        String res="";
        for(int i=0;i<s.length();i++){
            char ch=s.charAt(i);
            if(Character.isUpperCase(ch)){
                res+="_"+Character.toLowerCase(ch);
            }
            else{
                res+=ch;
            }
        }
        System.out.println(res);
    }
}
