import java.util.*;
public class Main{
    public static void main(String args[]){
    Scanner in=new Scanner(System.in);
    int n=in.nextInt();
    int arr[]=new int[n];
    int arr1[]=new int[n];
    for(int i=0;i<n;i++){
        arr[i]=in.nextInt();
    }
    for(int i=0;i<n;i++){
        arr1[i]=in.nextInt();
    }
    int decimal=0;
    for(int i=0;i<n;i++){
        int xor=arr[i]^arr1[i];
        decimal=decimal*2+xor;
    }
    System.out.println(decimal);
  }
}
