import java.util.*;
public class Main{
    public static void main(String args[]){
        Scanner in=new Scanner(System.in);
        String s=in.nextLine().toLowerCase();
        LinkedHashSet<Character> set=new LinkedHashSet<>();
        for(int i=0;i<s.length();i++){
            set.add(s.charAt(i));
        }
        String res="";
        for(char ch : set){
            res+=ch;
        }
        System.out.print(res);
    }
}
