import java.util.*;
public class Main{
    public static void main(String args[]){
        Scanner in=new Scanner(System.in);
        int n=in.nextInt();
        int arr[]=new int[n];
        for(int i=0;i<n;i++){
            arr[i]=in.nextInt();
        }
        int tcount=0;
        for(int i=0;i<n;i++){
            if(arr[i]-tcount>0){
                tcount++;
            }
        }
        System.out.println(tcount);
    }
}
